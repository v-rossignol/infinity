NODE_ENV=development
PORT=4000

# WebSocket event tracing at debug level (default: true in development, false in production)
WEBSOCKET_EVENT_LOGGING=true

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=infinity
POSTGRES_QUERY_LOGGING=false

# MongoDB
MONGO_URI=mongodb://localhost:27017/infinity

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=change-me-in-production

# Default admin (created on startup when the account does not exist)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change-me-in-production
DEFAULT_ADMIN_EMAIL=
